{
  "model_name": "DegVoC24k",
  "dataset_type": "LibriTTS",

  "data": {
    "train_list": "/data4/liandong/PROJECTS/DegVoC/DatasetsScp/LibriTTS/train-full.txt",
    "raw_wavfile_path": "/data4/liandong/datasets/LibriTTS/LibriTTS",
    "valid_list": "/data4/liandong/PROJECTS/DegVoC/DatasetsScp/LibriTTS/val-full.txt"
  },

  "train": {
    "batch_size": 16,
    "learning_rate": 0.0002,
    "adam_b1": 0.8,
    "adam_b2": 0.99,
    "training_steps": 2000000,
    "training_epochs": 5000,

    "stdout_interval": 500,
    "checkpoint_interval": 5000,
    "summary_interval": 500,
    "validation_interval": 5000,

    "clip_grad_norm": -1,
    "seed": 1234,
    "num_workers": 4,

    "checkpoint_path": "./exp/degvoc_libritts",
    "max_to_keep": 20,
    "save_best": true
  },

  "model": {
    "nstage": 8,
    "input_channel": 256,
    "hidden_channel": 256,
    "nb_num": 24,
    "use_even": false,

    "f_kernel_size": 9,
    "t_kernel_size": 11,
    "mlp_ratio": 1,
    "causal": false,

    "use_shared_encoder": true,
    "use_shared_decoder": true,

    "decode_type": "res+phase",
    "init_type": "pinv",
    "phit_learnable": true
  },

  "audio": {
    "sampling_rate": 24000,
    "segment_size": 16384,

    "num_mels": 100,
    "n_fft": 1024,
    "hop_size": 256,
    "win_size": 1024,

    "fmin": 0,
    "fmax": 12000
  },

  "loss": {
    "use_omni_phase_loss": true,
    "use_mag_weighted": false,

    "mpd_reshapes": [2, 3, 5, 7, 11],
    "mrd_resolutions": [
      [1024, 256, 1024],
      [2048, 512, 2048],
      [512, 128, 512]
    ],
    "mel_resolutions": [
      [32, 8, 32, 5],
      [64, 16, 64, 10],
      [128, 32, 128, 20],
      [256, 64, 256, 40],
      [512, 128, 512, 80],
      [1024, 256, 1024, 160],
      [2048, 512, 2048, 320]
    ],

    "weights": {
      "MelSpecReconstructLoss": 45.0,
      "GeneratorLoss": 1.0,
      "DiscriminatorLoss": 1.0,
      "FeatureMatchingLoss": 1.0,
      "RILoss": 45.0,
      "PhaseLoss": 100.0,
      "STFTConsistencyLoss": 45.0,
      "AmplitudeLoss": 45.0
    }
  }
}